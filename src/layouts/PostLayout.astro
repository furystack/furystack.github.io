---
import BaseLayout from './BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import ReadNext from '../components/ReadNext.astro';
import { Image } from 'astro:assets';
import { format } from 'date-fns';
import { SITE_URL } from '../consts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  prevPost?: CollectionEntry<'posts'> | null;
  nextPost?: CollectionEntry<'posts'> | null;
  relatedPosts?: CollectionEntry<'posts'>[];
  readingTime: string;
  authorData?: { id: string; avatar: string; bio: string }[];
}

const { post, prevPost, nextPost, relatedPosts = [], readingTime, authorData = [] } = Astro.props;
const { title, date, tags, excerpt, image, author } = post.data;

const datetime = format(date, 'yyyy-MM-dd');
const displayDatetime = format(date, 'dd LLL yyyy');

const ogImage = image ? new URL(image.src, SITE_URL).toString() : undefined;
const primaryTag = tags?.[0];
---

<BaseLayout title={title} description={excerpt} ogImage={ogImage} ogType="article">
  <div class="post-template">
    <header class="site-header">
      <div class="outer site-nav-main">
        <div class="inner">
          <SiteNav />
        </div>
      </div>
    </header>

    <main id="site-main" class="site-main outer">
      <div class="inner">
        <article class:list={['post-full', { 'no-image': !image }]}>
          <header class="post-full-header">
            {primaryTag && (
              <section class="post-full-tags">
                <a href={`/tags/${primaryTag.toLowerCase().replace(/\s+/g, '-')}/`}>{primaryTag}</a>
              </section>
            )}
            <h1 class="post-full-title">{title}</h1>
            {excerpt && <p class="post-full-excerpt">{excerpt}</p>}
            <div class="post-full-byline">
              <section class="post-full-byline-content">
                <div class="author-list">
                  {authorData.map(a => (
                    <a class="author-avatar" href={`/author/${a.id.toLowerCase()}/`}>
                      <img class="author-profile-image" src={a.avatar} alt={a.id} />
                    </a>
                  ))}
                </div>
                <section class="post-full-byline-meta">
                  <h4 class="author-name">
                    {author.map((authorId, i) => (
                      <>
                        <a href={`/author/${authorId.toLowerCase()}/`}>{authorId}</a>
                        {i < author.length - 1 && ', '}
                      </>
                    ))}
                  </h4>
                  <div class="byline-meta-content">
                    <time class="byline-meta-date" datetime={datetime}>{displayDatetime}</time>
                    <span class="bull">&bull;</span>
                    <span>{readingTime}</span>
                  </div>
                </section>
              </section>
            </div>
          </header>

          {image && (
            <figure class="post-full-image">
              <Image src={image} alt={title} width={1920} height={1080} />
            </figure>
          )}

          <section class="post-full-content">
            <div class="post-content">
              <slot />
            </div>
          </section>
        </article>
      </div>
    </main>

    <ReadNext
      currentSlug={post.id}
      tags={tags || []}
      relatedPosts={relatedPosts}
      prevPost={prevPost}
      nextPost={nextPost}
    />

    <Footer />
  </div>
</BaseLayout>

<style>
  .post-template .site-main {
    margin-top: 64px;
    background: #fff;
    padding-bottom: 4vw;
  }

  @media (prefers-color-scheme: dark) {
    .post-template .site-main {
      background: var(--color-darkmode);
    }
  }

  .post-full {
    position: relative;
    z-index: 50;
  }

  .no-image .post-full-content {
    padding-top: 0;
  }
  .no-image .post-full-content:before,
  .no-image .post-full-content:after {
    display: none;
  }

  .post-full-header {
    position: relative;
    margin: 0 auto;
    padding: 70px 170px 50px;
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
  }
  @media (max-width: 1170px) { .post-full-header { padding: 60px 11vw 50px; } }
  @media (max-width: 800px) { .post-full-header { padding-right: 5vw; padding-left: 5vw; } }
  @media (max-width: 500px) { .post-full-header { padding: 20px 0 35px; } }

  .post-full-tags {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    color: var(--color-midgrey);
    font-size: 1.3rem;
    line-height: 1.4em;
    font-weight: 600;
    text-transform: uppercase;
  }

  .post-full-title {
    margin: 0 0 0.2em;
    color: #0d0e10;
  }
  @media (max-width: 500px) { .post-full-title { margin-top: 0.2em; font-size: 3.3rem; } }
  @media (prefers-color-scheme: dark) { .post-full-title { color: rgba(255, 255, 255, 0.9); } }

  .post-full-excerpt {
    margin: 20px 0 0;
    color: var(--color-midgrey);
    font-family: Georgia, serif;
    font-size: 2.3rem;
    line-height: 1.4em;
    font-weight: 300;
  }
  @media (max-width: 500px) { .post-full-excerpt { font-size: 1.9rem; line-height: 1.5em; } }
  @media (prefers-color-scheme: dark) { .post-full-excerpt { color: var(--color-midgrey-l10); } }

  .post-full-byline {
    display: flex;
    justify-content: space-between;
    margin: 35px 0 0;
    padding-top: 15px;
    border-top: 1px solid var(--color-lightgrey-l10);
  }
  @media (prefers-color-scheme: dark) { .post-full-byline { border-top-color: var(--color-darkmode-l15); } }

  .post-full-byline-content {
    flex-grow: 1;
    display: flex;
    align-items: flex-start;
  }

  .author-list {
    display: flex;
    flex-wrap: wrap;
    margin: 0 0 0 4px;
    padding: 0 12px 0 0;
    list-style: none;
  }

  .author-avatar {
    display: block;
    overflow: hidden;
    margin: 0 -4px;
    width: 40px;
    height: 40px;
    border: #fff 2px solid;
    border-radius: 100%;
  }
  @media (prefers-color-scheme: dark) { .author-avatar { border-color: var(--color-darkgrey-l02); } }

  .author-profile-image {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--color-lightgrey-l10);
    border-radius: 100%;
    object-fit: cover;
  }
  @media (prefers-color-scheme: dark) { .author-profile-image { background: var(--color-darkmode); } }

  .post-full-byline-meta {
    margin: 2px 0 0;
    color: var(--color-midgrey-l10);
    font-size: 1.2rem;
    line-height: 1.2em;
    letter-spacing: 0.2px;
    text-transform: uppercase;
  }
  .post-full-byline-meta h4 { margin: 0 0 3px; font-size: 1.3rem; line-height: 1.4em; font-weight: 500; }
  .post-full-byline-meta h4 a { color: var(--color-darkgrey-l10); }
  .post-full-byline-meta h4 a:hover { color: var(--color-darkgrey); text-decoration: none; }
  .post-full-byline-meta .bull { display: inline-block; margin: 0 4px; opacity: 0.6; }
  @media (prefers-color-scheme: dark) {
    .post-full-byline-meta h4 a { color: rgba(255, 255, 255, 0.75); }
    .post-full-byline-meta h4 a:hover { color: #fff; }
  }

  .post-full-image {
    margin: 25px 0 50px;
    height: 800px;
    background: var(--color-lightgrey) center center;
    background-size: cover;
    border-radius: 5px;
    overflow: hidden;
  }
  .post-full-image :global(img) { width: 100%; height: 100%; object-fit: cover; }
  @media (max-width: 1170px) { .post-full-image { margin: 25px -6vw 50px; border-radius: 0; } }
  @media (max-width: 800px) { .post-full-image { height: 400px; } }
  @media (max-width: 500px) { .post-full-image { margin-bottom: 4vw; height: 350px; } }

  .post-full-content {
    position: relative;
    margin: 0 auto;
    padding: 0 170px 6vw;
    min-height: 230px;
    font-family: Georgia, serif;
    font-size: 2rem;
    line-height: 1.6em;
    background: #fff;
  }
  @media (max-width: 1170px) { .post-full-content { padding: 0 11vw; } }
  @media (max-width: 800px) { .post-full-content { padding: 0 5vw; font-size: 1.8rem; } }
  @media (max-width: 500px) { .post-full-content { padding: 0; } }

  @media (prefers-color-scheme: dark) {
    .post-full-content { background: var(--color-darkmode); }
  }

  /* Post content typography */
  .post-full-content :global(h1),
  .post-full-content :global(h2),
  .post-full-content :global(h3),
  .post-full-content :global(h4),
  .post-full-content :global(h5),
  .post-full-content :global(h6),
  .post-full-content :global(p),
  .post-full-content :global(ul),
  .post-full-content :global(ol),
  .post-full-content :global(dl),
  .post-full-content :global(pre),
  .post-full-content :global(blockquote) {
    margin: 0 0 1.5em 0;
    min-width: 100%;
  }

  .post-full-content :global(a) {
    color: var(--color-darkgrey);
    word-break: break-word;
    box-shadow: var(--color-darkgrey) 0 -1px 0 inset;
    transition: all 0.2s ease-in-out;
  }
  .post-full-content :global(a:hover) {
    color: var(--color-blue);
    text-decoration: none;
    box-shadow: var(--color-blue) 0 -1px 0 inset;
  }

  .post-full-content :global(strong),
  .post-full-content :global(em) { color: #0e0f11; }

  .post-full-content :global(img),
  .post-full-content :global(video) {
    display: block;
    margin: 1.5em auto;
    max-width: 1040px;
    height: auto;
  }
  @media (max-width: 1040px) {
    .post-full-content :global(img),
    .post-full-content :global(video) { width: 100%; }
  }

  .post-full-content :global(code) {
    padding: 0 5px 2px;
    font-size: 0.8em;
    line-height: 1em;
    font-weight: 400 !important;
    background: var(--color-whitegrey);
    border-radius: 3px;
  }

  .post-full-content :global(pre) {
    overflow-x: auto;
    padding: 20px;
    max-width: 100%;
    border-radius: 5px;
    font-size: 1.4rem;
    line-height: 1.5em;
  }
  .post-full-content :global(pre code) {
    padding: 0;
    font-size: inherit;
    line-height: inherit;
    background: transparent;
  }

  .post-full-content :global(blockquote) {
    margin: 0 0 1.5em;
    padding: 0 1.5em;
    border-left: var(--color-blue) 3px solid;
  }
  .post-full-content :global(blockquote p) {
    margin: 0 0 1em 0;
    color: inherit;
    font-size: inherit;
    line-height: inherit;
    font-style: italic;
  }

  .post-full-content :global(h1),
  .post-full-content :global(h2),
  .post-full-content :global(h3),
  .post-full-content :global(h4),
  .post-full-content :global(h5),
  .post-full-content :global(h6) {
    color: #0e0f11;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  }

  .post-full-content :global(h1) { font-size: 4.2rem; line-height: 1.25em; font-weight: 600; }
  .post-full-content :global(h2) { font-size: 3.2rem; line-height: 1.25em; font-weight: 600; }
  .post-full-content :global(h3) { font-size: 2.5rem; line-height: 1.3em; font-weight: 600; }
  .post-full-content :global(h4) { font-size: 2.5rem; font-weight: 600; }
  .post-full-content :global(h5) {
    display: block;
    padding: 0.4em 1em 0.9em;
    border: 0;
    color: var(--color-blue);
    font-family: Georgia, serif;
    font-size: 3.2rem;
    line-height: 1.35em;
    text-align: center;
  }
  .post-full-content :global(h6) { font-size: 2rem; font-weight: 700; }

  .post-full-content :global(table) {
    display: inline-block;
    overflow-x: auto;
    margin: 0.5em 0 2.5em;
    max-width: 100%;
    width: auto;
    border-spacing: 0;
    border-collapse: collapse;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    font-size: 1.6rem;
    white-space: nowrap;
    vertical-align: top;
  }
  .post-full-content :global(table th) {
    color: var(--color-darkgrey);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.2px;
    text-align: left;
    text-transform: uppercase;
    background-color: var(--color-whitegrey-l04);
  }
  .post-full-content :global(table th),
  .post-full-content :global(table td) {
    padding: 6px 12px;
    border: var(--color-whitegrey) 1px solid;
  }

  @media (prefers-color-scheme: dark) {
    .post-full-content :global(h1),
    .post-full-content :global(h2),
    .post-full-content :global(h3),
    .post-full-content :global(h4),
    .post-full-content :global(h6) { color: rgba(255, 255, 255, 0.9); }
    .post-full-content :global(a) { color: #fff; box-shadow: inset 0 -1px 0 #fff; }
    .post-full-content :global(strong),
    .post-full-content :global(em) { color: #fff; }
    .post-full-content :global(code) { color: #fff; background: #000; }
    .post-full-content :global(table th) {
      color: rgba(255, 255, 255, 0.85);
      background-color: var(--color-darkmode-l08);
    }
    .post-full-content :global(table th),
    .post-full-content :global(table td) { border: var(--color-darkmode-l08) 1px solid; }
  }
</style>
