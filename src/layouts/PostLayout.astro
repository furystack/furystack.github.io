---
import BaseLayout from './BaseLayout.astro';
import ReadNext from '../components/ReadNext.astro';
import { Image } from 'astro:assets';
import { format } from 'date-fns';
import { SITE_URL } from '../consts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  prevPost?: CollectionEntry<'posts'> | null;
  nextPost?: CollectionEntry<'posts'> | null;
  relatedPosts?: CollectionEntry<'posts'>[];
  readingTime: string;
  authorData?: { id: string; avatar: string; bio: string }[];
}

const { post, prevPost, nextPost, relatedPosts = [], readingTime, authorData = [] } = Astro.props;
const { title, date, tags, excerpt, image, author } = post.data;

const datetime = format(date, 'yyyy-MM-dd');
const displayDatetime = format(date, 'dd LLL yyyy');

const ogImage = image ? new URL(image.src, SITE_URL).toString() : undefined;
const primaryTag = tags?.[0];
---

<BaseLayout title={title} description={excerpt ?? undefined} ogImage={ogImage} ogType="article">
  <main id="main-content" class="post-main">
    <article class="post-article">
      <header class="post-header">
        {
          primaryTag && (
            <a class="post-tag" href={`/tags/${primaryTag.toLowerCase().replace(/\s+/g, '-')}/`}>
              {primaryTag}
            </a>
          )
        }
        <h1 class="post-title">{title}</h1>
        {excerpt && <p class="post-excerpt">{excerpt}</p>}
        <div class="post-byline">
          {
            authorData.map(a => (
              <a class="byline-avatar" href={`/author/${a.id.toLowerCase()}/`}>
                <img src={a.avatar} alt={a.id} width="36" height="36" loading="eager" />
              </a>
            ))
          }
          <div class="byline-text">
            <span class="byline-authors">
              {
                author.map((authorId, i) => (
                  <>
                    <a href={`/author/${authorId.toLowerCase()}/`}>{authorId}</a>
                    {i < author.length - 1 && ', '}
                  </>
                ))
              }
            </span>
            <span class="byline-meta">
              <time datetime={datetime}>{displayDatetime}</time>
              <span>&middot;</span>
              <span>{readingTime}</span>
            </span>
          </div>
        </div>
      </header>

      {
        image && (
          <figure class="post-image">
            <Image
              src={image}
              alt={title}
              width={1920}
              height={1080}
              format="jpg"
              loading="eager"
            />
          </figure>
        )
      }

      <section class="post-content">
        <slot />
      </section>
    </article>
  </main>

  <ReadNext
    currentSlug={post.id}
    relatedPosts={relatedPosts}
    prevPost={prevPost}
    nextPost={nextPost}
  />
</BaseLayout>

<style>
  .post-main {
    flex-grow: 1;
    padding: calc(64px + 48px) 5vw 60px;
    background: #fff;
  }
  @media (prefers-color-scheme: dark) {
    .post-main {
      background: var(--color-darkmode);
    }
  }

  .post-article {
    max-width: 780px;
    margin: 0 auto;
  }

  /* Header */
  .post-header {
    margin-bottom: 40px;
  }

  .post-tag {
    display: inline-block;
    margin-bottom: 12px;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
  }
  .post-tag:hover {
    text-decoration: underline;
  }

  .post-title {
    font-size: 4rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 16px;
  }
  @media (max-width: 600px) {
    .post-title {
      font-size: 2.8rem;
    }
  }
  @media (prefers-color-scheme: dark) {
    .post-title {
      color: rgba(255, 255, 255, 0.95);
    }
  }

  .post-excerpt {
    font-size: 2rem;
    line-height: 1.5;
    color: var(--color-midgrey);
    margin-bottom: 24px;
  }
  @media (max-width: 600px) {
    .post-excerpt {
      font-size: 1.7rem;
    }
  }
  @media (prefers-color-scheme: dark) {
    .post-excerpt {
      color: rgba(255, 255, 255, 0.5);
    }
  }

  .post-byline {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }
  @media (prefers-color-scheme: dark) {
    .post-byline {
      border-top-color: var(--color-darkmode-border);
    }
  }

  .byline-avatar {
    display: block;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }
  .byline-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .byline-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .byline-authors {
    font-size: 1.4rem;
    font-weight: 600;
  }
  .byline-authors a {
    color: var(--color-darkgrey);
    text-decoration: none;
  }
  .byline-authors a:hover {
    text-decoration: underline;
  }
  @media (prefers-color-scheme: dark) {
    .byline-authors a {
      color: rgba(255, 255, 255, 0.85);
    }
  }

  .byline-meta {
    display: flex;
    gap: 6px;
    font-size: 1.3rem;
    color: var(--color-midgrey);
  }

  /* Image */
  .post-image {
    margin: 0 -5vw 40px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-height: 600px;
  }
  .post-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 800px) {
    .post-image {
      margin: 0 0 32px;
      max-height: 400px;
    }
  }

  /* Content */
  .post-content {
    font-size: 1.85rem;
    line-height: 1.72;
    color: var(--color-body);
  }
  @media (max-width: 600px) {
    .post-content {
      font-size: 1.7rem;
    }
  }

  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4),
  .post-content :global(h5),
  .post-content :global(h6),
  .post-content :global(p),
  .post-content :global(ul),
  .post-content :global(ol),
  .post-content :global(dl),
  .post-content :global(pre),
  .post-content :global(blockquote) {
    margin: 0 0 1.5em 0;
  }

  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4),
  .post-content :global(h5),
  .post-content :global(h6) {
    font-family: var(--font-sans);
    color: var(--color-darkgrey);
    margin-top: 1.5em;
  }
  .post-content :global(h1) {
    font-size: 3.6rem;
  }
  .post-content :global(h2) {
    font-size: 2.8rem;
  }
  .post-content :global(h3) {
    font-size: 2.2rem;
  }
  .post-content :global(h4) {
    font-size: 2rem;
  }
  .post-content :global(h5) {
    font-size: 2.4rem;
    color: var(--color-accent);
    font-family: var(--font-sans);
    text-align: center;
    padding: 0.5em 0;
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: rgba(59, 130, 246, 0.3);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.15s ease;
  }
  .post-content :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  .post-content :global(strong) {
    font-weight: 600;
    color: var(--color-darkgrey);
  }

  .post-content :global(img),
  .post-content :global(video) {
    display: block;
    margin: 1.5em auto;
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    padding: 0.15em 0.4em;
    background: var(--color-whitegrey);
    border-radius: 4px;
  }
  .post-content :global(pre) {
    overflow-x: auto;
    padding: 1.2em 1.5em;
    border-radius: var(--radius-md);
    font-size: 1.4rem;
    line-height: 1.55;
  }
  .post-content :global(pre code) {
    padding: 0;
    background: transparent;
    font-size: inherit;
  }

  .post-content :global(blockquote) {
    padding: 0 0 0 1.5em;
    border-left: 3px solid var(--color-accent);
    color: var(--color-midgrey);
  }
  .post-content :global(blockquote p) {
    font-style: italic;
  }

  .post-content :global(table) {
    display: block;
    overflow-x: auto;
    width: 100%;
    border-collapse: collapse;
    font-size: 1.5rem;
    margin: 1em 0 2em;
  }
  .post-content :global(table th),
  .post-content :global(table td) {
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    text-align: left;
  }
  .post-content :global(table th) {
    font-weight: 600;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: var(--color-whitegrey);
  }

  @media (prefers-color-scheme: dark) {
    .post-content {
      color: rgba(255, 255, 255, 0.72);
    }
    .post-content :global(h1),
    .post-content :global(h2),
    .post-content :global(h3),
    .post-content :global(h4),
    .post-content :global(h6) {
      color: rgba(255, 255, 255, 0.92);
    }
    .post-content :global(strong) {
      color: rgba(255, 255, 255, 0.92);
    }
    .post-content :global(a) {
      color: #60a5fa;
      text-decoration-color: rgba(96, 165, 250, 0.3);
    }
    .post-content :global(a:hover) {
      text-decoration-color: #60a5fa;
    }
    .post-content :global(code) {
      background: var(--color-darkmode-l08);
      color: rgba(255, 255, 255, 0.85);
    }
    .post-content :global(table th) {
      background: var(--color-darkmode-l08);
      color: rgba(255, 255, 255, 0.85);
    }
    .post-content :global(table th),
    .post-content :global(table td) {
      border-color: var(--color-darkmode-border);
    }
  }
</style>
