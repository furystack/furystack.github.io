---
import BaseLayout from './BaseLayout.astro';
import { format } from 'date-fns';
import type { CollectionEntry } from 'astro:content';

interface Props {
  doc: CollectionEntry<'docs'>;
}

const { doc } = Astro.props;
const { title, description, package: pkg, lastVerified } = doc.data;
const verifiedDate = format(lastVerified, 'dd LLL yyyy');
---

<BaseLayout title={title} description={description}>
  <main id="main-content" class="doc-main">
    <div class="doc-inner">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/getting-started/">Getting Started</a>
        <span aria-hidden="true">/</span>
        <span>{title}</span>
      </nav>

      <header class="doc-header">
        {pkg && <span class="doc-package">{pkg}</span>}
        <h1>{title}</h1>
        <p class="doc-description">{description}</p>
        <div class="doc-meta">
          <span class="doc-meta-label">Always reflects the latest API.</span>
          <span class="doc-meta-sep">&middot;</span>
          <span
            >Last verified <time datetime={lastVerified.toISOString()}>{verifiedDate}</time></span
          >
        </div>
      </header>

      <article class="doc-content">
        <slot />
      </article>
    </div>
  </main>
</BaseLayout>

<style>
  .doc-main {
    flex-grow: 1;
    padding: calc(64px + 48px) 5vw 80px;
    background: #fff;
  }
  @media (prefers-color-scheme: dark) {
    .doc-main {
      background: var(--color-darkmode);
    }
  }

  .doc-inner {
    max-width: 820px;
    margin: 0 auto;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    font-size: 1.4rem;
    color: var(--color-midgrey);
  }
  .breadcrumb a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .doc-header {
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-border);
  }
  @media (prefers-color-scheme: dark) {
    .doc-header {
      border-bottom-color: var(--color-darkmode-border);
    }
  }

  .doc-package {
    display: inline-block;
    margin-bottom: 12px;
    padding: 4px 10px;
    font-family: var(--font-mono);
    font-size: 1.2rem;
    color: var(--color-accent);
    background: rgba(59, 130, 246, 0.08);
    border-radius: var(--radius-sm, 4px);
  }
  @media (prefers-color-scheme: dark) {
    .doc-package {
      background: rgba(59, 130, 246, 0.15);
    }
  }

  .doc-header h1 {
    font-size: 3.6rem;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }
  @media (max-width: 600px) {
    .doc-header h1 {
      font-size: 2.6rem;
    }
  }

  .doc-description {
    font-size: 1.9rem;
    line-height: 1.5;
    color: var(--color-midgrey);
    margin-bottom: 16px;
  }
  @media (prefers-color-scheme: dark) {
    .doc-description {
      color: rgba(255, 255, 255, 0.65);
    }
  }

  .doc-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    font-size: 1.3rem;
    color: var(--color-midgrey);
  }
  .doc-meta-label {
    font-weight: 600;
    color: var(--color-accent);
  }
  .doc-meta-sep {
    opacity: 0.5;
  }

  .doc-content {
    font-size: 1.7rem;
    line-height: 1.7;
    color: var(--color-body);
  }
  @media (prefers-color-scheme: dark) {
    .doc-content {
      color: rgba(255, 255, 255, 0.72);
    }
  }

  .doc-content :global(h1),
  .doc-content :global(h2),
  .doc-content :global(h3),
  .doc-content :global(h4),
  .doc-content :global(p),
  .doc-content :global(ul),
  .doc-content :global(ol),
  .doc-content :global(pre),
  .doc-content :global(blockquote),
  .doc-content :global(table) {
    margin: 0 0 1.4em 0;
  }

  .doc-content :global(h1),
  .doc-content :global(h2),
  .doc-content :global(h3),
  .doc-content :global(h4) {
    font-family: var(--font-sans);
    color: var(--color-darkgrey);
    margin-top: 1.6em;
    letter-spacing: -0.01em;
  }
  .doc-content :global(h2) {
    font-size: 2.4rem;
  }
  .doc-content :global(h3) {
    font-size: 1.9rem;
  }
  .doc-content :global(h4) {
    font-size: 1.7rem;
  }

  .doc-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: rgba(59, 130, 246, 0.3);
    text-underline-offset: 2px;
  }
  .doc-content :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  .doc-content :global(strong) {
    font-weight: 600;
    color: var(--color-darkgrey);
  }

  .doc-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    padding: 0.15em 0.4em;
    background: var(--color-whitegrey);
    border-radius: 4px;
  }
  .doc-content :global(pre) {
    overflow-x: auto;
    padding: 1.2em 1.5em;
    border-radius: var(--radius-md);
    font-size: 1.4rem;
    line-height: 1.55;
    background: var(--color-darkgrey);
    color: rgba(255, 255, 255, 0.9);
  }
  .doc-content :global(pre code) {
    padding: 0;
    background: transparent;
    color: inherit;
    font-size: inherit;
  }

  .doc-content :global(blockquote) {
    padding: 0.8em 1.2em;
    border-left: 3px solid var(--color-accent);
    background: rgba(59, 130, 246, 0.05);
    color: var(--color-darkgrey);
    border-radius: 0 var(--radius-sm, 4px) var(--radius-sm, 4px) 0;
  }
  .doc-content :global(blockquote p) {
    margin: 0;
  }
  .doc-content :global(blockquote p + p) {
    margin-top: 0.8em;
  }
  @media (prefers-color-scheme: dark) {
    .doc-content :global(blockquote) {
      background: rgba(96, 165, 250, 0.08);
      color: rgba(255, 255, 255, 0.85);
    }
  }

  .doc-content :global(ul),
  .doc-content :global(ol) {
    padding-left: 1.6em;
  }
  .doc-content :global(li) {
    margin-bottom: 0.4em;
  }

  .doc-content :global(table) {
    display: block;
    overflow-x: auto;
    width: 100%;
    border-collapse: collapse;
    font-size: 1.4rem;
  }
  .doc-content :global(table th),
  .doc-content :global(table td) {
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    text-align: left;
  }
  .doc-content :global(table th) {
    font-weight: 600;
    background: var(--color-whitegrey);
  }
  .doc-content :global(hr) {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 2em 0;
  }

  @media (prefers-color-scheme: dark) {
    .doc-content :global(h1),
    .doc-content :global(h2),
    .doc-content :global(h3),
    .doc-content :global(h4) {
      color: rgba(255, 255, 255, 0.92);
    }
    .doc-content :global(strong) {
      color: rgba(255, 255, 255, 0.92);
    }
    .doc-content :global(a) {
      color: #60a5fa;
      text-decoration-color: rgba(96, 165, 250, 0.3);
    }
    .doc-content :global(a:hover) {
      text-decoration-color: #60a5fa;
    }
    .doc-content :global(code) {
      background: var(--color-darkmode-l08);
      color: rgba(255, 255, 255, 0.85);
    }
    .doc-content :global(pre) {
      background: var(--color-darkmode-l04);
    }
    .doc-content :global(table th) {
      background: var(--color-darkmode-l08);
    }
    .doc-content :global(table th),
    .doc-content :global(table td) {
      border-color: var(--color-darkmode-border);
    }
    .doc-content :global(hr) {
      border-top-color: var(--color-darkmode-border);
    }
  }
</style>
