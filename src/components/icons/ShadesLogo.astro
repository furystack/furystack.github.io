---
interface Props {
  size?: number;
}

const { size = 96 } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 512 512"
  width={size}
  height={size}
  aria-hidden="true"
  class="shades-logo"
>
  <title>Shades</title>
  <defs>
    <linearGradient id="sh-left" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#818cf8"></stop>
      <stop offset="100%" stop-color="#4338ca"></stop>
    </linearGradient>
    <linearGradient id="sh-center" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#a78bfa"></stop>
      <stop offset="100%" stop-color="#6d28d9"></stop>
    </linearGradient>
    <linearGradient id="sh-right" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#c084fc"></stop>
      <stop offset="100%" stop-color="#9333ea"></stop>
    </linearGradient>

    <filter id="sh-shadow" x="-10%" y="-10%" width="120%" height="120%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="8" result="blur"></feGaussianBlur>
      <feOffset dx="0" dy="6" result="offset"></feOffset>
      <feFlood flood-color="#4c1d95" flood-opacity="0.2" result="color"></feFlood>
      <feComposite in="color" in2="offset" operator="in" result="shadow"></feComposite>
      <feMerge>
        <feMergeNode in="shadow"></feMergeNode>
        <feMergeNode in="SourceGraphic"></feMergeNode>
      </feMerge>
    </filter>
  </defs>

  <g filter="url(#sh-shadow)">
    <!-- Left panel (back) -->
    <g class="sh-panel sh-panel-1" transform="rotate(-12, 179, 260)">
      <rect x="84" y="110" width="190" height="300" rx="22" fill="url(#sh-left)" opacity="0.7"
      ></rect>
      <rect x="106" y="138" width="100" height="4" rx="2" fill="#fff" opacity="0.15"></rect>
      <rect x="106" y="152" width="70" height="4" rx="2" fill="#fff" opacity="0.1"></rect>
    </g>

    <!-- Right panel (back) -->
    <g class="sh-panel sh-panel-3" transform="rotate(12, 333, 260)">
      <rect x="238" y="110" width="190" height="300" rx="22" fill="url(#sh-right)" opacity="0.7"
      ></rect>
      <rect x="260" y="138" width="100" height="4" rx="2" fill="#fff" opacity="0.15"></rect>
      <rect x="260" y="152" width="70" height="4" rx="2" fill="#fff" opacity="0.1"></rect>
    </g>

    <!-- Center panel (front) -->
    <g class="sh-panel sh-panel-2">
      <rect x="151" y="90" width="210" height="320" rx="24" fill="url(#sh-center)" opacity="0.85"
      ></rect>
      <rect x="177" y="122" width="120" height="5" rx="2.5" fill="#fff" opacity="0.2"></rect>
      <rect x="177" y="138" width="80" height="4" rx="2" fill="#fff" opacity="0.12"></rect>
      <rect x="177" y="152" width="100" height="4" rx="2" fill="#fff" opacity="0.08"></rect>
      <circle cx="256" cy="260" r="36" fill="none" stroke="#fff" stroke-width="2.5" opacity="0.15"
      ></circle>
      <circle cx="256" cy="260" r="16" fill="#fff" opacity="0.1"></circle>
    </g>
  </g>
</svg>

<style>
  .shades-logo {
    overflow: visible;
  }

  @media (prefers-reduced-motion: no-preference) {
    .sh-panel {
      opacity: 0;
      animation: sh-fan 0.7s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    .sh-panel-1 {
      animation-delay: 0s;
    }
    .sh-panel-3 {
      animation-delay: 0.1s;
    }
    .sh-panel-2 {
      animation-delay: 0.2s;
    }

    @keyframes sh-fan {
      from {
        opacity: 0;
        transform: scale(0.85) translateY(12px);
      }
      to {
        opacity: 1;
        transform: scale(1) translateY(0);
      }
    }
  }
</style>
