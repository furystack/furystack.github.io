---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import PostCard from '../components/PostCard.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, SOCIAL } from '../consts';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const [featured, ...rest] = posts;

const ogImage = `${SITE_URL}/images/blog-cover.png`;
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} ogImage={ogImage}>
  <div class="home">
    <div class="site-nav-main">
      <div class="inner" style="padding: 0 5vw;">
        <SiteNav isHome />
      </div>
    </div>

    <section class="hero">
      <div class="hero-inner">
        <img class="hero-logo" src="/images/furystack-logo-512.png" alt={SITE_TITLE} width="64" height="64" />
        <h1 class="hero-title">FuryStack</h1>
        <p class="hero-description">{SITE_DESCRIPTION}</p>
        <div class="hero-actions">
          <a href="/tags/getting-started/" class="btn btn-primary">Get Started</a>
          <a href={SOCIAL.github} class="btn btn-ghost" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" style="margin-right: 6px; vertical-align: -3px;"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
          </a>
        </div>
      </div>
    </section>

    <main class="main-content">
      <div class="inner">
        {featured && (
          <section class="featured-section">
            <span class="section-label">Latest</span>
            <PostCard post={featured} large />
          </section>
        )}

        {rest.length > 0 && (
          <section class="posts-section">
            <span class="section-label">All Posts</span>
            <div class="posts-grid">
              {rest.map(post => <PostCard post={post} />)}
            </div>
          </section>
        )}
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* Hero */
  .hero {
    position: relative;
    padding: calc(64px + 6vw) 5vw 6vw;
    background: var(--color-nav-bg);
    color: #fff;
    text-align: center;
    overflow: hidden;
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-logo {
    width: 64px;
    height: 64px;
    margin: 0 auto 20px;
    border-radius: var(--radius-md);
  }

  .hero-title {
    font-size: 4.8rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 12px;
  }
  @media (max-width: 600px) { .hero-title { font-size: 3.2rem; } }

  .hero-description {
    font-size: 1.9rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 32px;
    font-weight: 400;
  }
  @media (max-width: 600px) { .hero-description { font-size: 1.6rem; } }

  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    font-size: 1.5rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .btn:hover { text-decoration: none; }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }
  .btn-primary:hover { background: var(--color-accent-hover); }

  .btn-ghost {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }
  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
  }

  /* Main content */
  .main-content {
    flex-grow: 1;
    padding: 48px 5vw 80px;
    background: var(--color-whitegrey);
  }
  @media (prefers-color-scheme: dark) {
    .main-content { background: var(--color-darkmode); }
  }

  .section-label {
    display: block;
    margin-bottom: 20px;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-midgrey);
  }

  .featured-section {
    margin-bottom: 48px;
  }

  .posts-section {
    margin-bottom: 24px;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 28px;
  }
  @media (max-width: 600px) {
    .posts-grid { grid-template-columns: 1fr; gap: 20px; }
  }
</style>
