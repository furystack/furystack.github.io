---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import GitHubIcon from '../components/icons/GitHubIcon.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, SOCIAL } from '../consts';
import logo from '../../public/images/furystack-logo-512.png';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const [featured, ...rest] = posts;

const ogImage = `${SITE_URL}/images/blog-cover.png`;
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} ogImage={ogImage} isHome>
  <section class="hero">
    <div class="hero-inner">
      <Image class="hero-logo" src={logo} alt={SITE_TITLE} width={64} height={64} loading="eager" />
      <h1 class="hero-title">FuryStack</h1>
      <p class="hero-description">{SITE_DESCRIPTION}</p>
      <div class="hero-actions">
        <a href="/tags/getting-started/" class="btn btn-primary">Get Started</a>
        <a href={SOCIAL.github} class="btn btn-ghost" target="_blank" rel="noopener noreferrer">
          <GitHubIcon />
          <span style="margin-left: 6px;">GitHub</span>
        </a>
      </div>
    </div>
  </section>

  <main id="main-content" class="main-content">
    <div class="inner">
      {featured && (
        <section class="featured-section">
          <span class="section-label">Latest</span>
            <PostCard post={featured} large eager />
        </section>
      )}

      {rest.length > 0 && (
        <section class="posts-section">
          <span class="section-label">All Posts</span>
          <div class="posts-grid">
            {rest.map((post, i) => <PostCard post={post} eager={i < 3} />)}
          </div>
        </section>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: calc(64px + 6vw) 5vw 6vw;
    background: var(--color-nav-bg);
    color: #fff;
    text-align: center;
    overflow: hidden;
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-logo {
    width: 64px;
    height: 64px;
    margin: 0 auto 20px;
    border-radius: var(--radius-md);
  }

  .hero-title {
    font-size: 4.8rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 12px;
  }
  @media (max-width: 600px) { .hero-title { font-size: 3.2rem; } }

  .hero-description {
    font-size: 1.9rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 32px;
    font-weight: 400;
  }
  @media (max-width: 600px) { .hero-description { font-size: 1.6rem; } }

  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    font-size: 1.5rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .btn:hover { text-decoration: none; }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }
  .btn-primary:hover { background: var(--color-accent-hover); }

  .btn-ghost {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }
  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
  }

  /* Main content */
  .main-content {
    flex-grow: 1;
    padding: 48px 5vw 80px;
    background: var(--color-whitegrey);
  }
  @media (prefers-color-scheme: dark) {
    .main-content { background: var(--color-darkmode); }
  }

  .section-label {
    display: block;
    margin-bottom: 20px;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-midgrey);
  }

  .featured-section {
    margin-bottom: 48px;
  }

  .posts-section {
    margin-bottom: 24px;
  }
</style>
